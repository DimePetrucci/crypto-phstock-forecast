APP_NAME="AI Investment Intelligence Platform"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT=development

# CORS — comma-separated
ALLOWED_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/investment_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_256BIT_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# External APIs
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINGECKO_API_KEY=
ANTHROPIC_API_KEY=

# Binance
BINANCE_BASE_URL=https://api.binance.com
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443

# CoinGecko
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Market data cache TTLs (seconds)
MARKET_PRICE_CACHE_TTL=10
MARKET_OHLCV_CACHE_TTL=60
MARKET_INDICATORS_CACHE_TTL=60
COINGECKO_CACHE_TTL=300

# Tracked crypto symbols (comma-separated)
TRACKED_CRYPTO_SYMBOLS=["BTCUSDT","ETHUSDT","BNBUSDT","SOLUSDT","ADAUSDT"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
